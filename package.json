{
  "name": "k7s",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "description": "k7s — a dark, Lens-style Kubernetes visual monitor built with Tauri + React.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
